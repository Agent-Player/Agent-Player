{
  "id": "calendar",
  "name": "Calendar System",
  "version": "1.0.0",
  "description": "Calendar events with Google Calendar and iCal sync",
  "author": "Agent Player Team",
  "type": "app",
  "main": "src/index.js",

  "capabilities": {
    "database": true,
    "routes": true,
    "cron": true,
    "tools": false,
    "frontend": true
  },

  "routes": [
    {
      "method": "GET",
      "path": "/api/calendar/events",
      "description": "Get calendar events"
    },
    {
      "method": "POST",
      "path": "/api/calendar/events",
      "description": "Create calendar event"
    },
    {
      "method": "PUT",
      "path": "/api/calendar/events/:id",
      "description": "Update calendar event"
    },
    {
      "method": "DELETE",
      "path": "/api/calendar/events/:id",
      "description": "Delete calendar event"
    },
    {
      "method": "GET",
      "path": "/api/calendar/sources",
      "description": "Get calendar sources"
    },
    {
      "method": "POST",
      "path": "/api/calendar/sources",
      "description": "Add calendar source"
    },
    {
      "method": "PUT",
      "path": "/api/calendar/sources/:id",
      "description": "Update calendar source"
    },
    {
      "method": "DELETE",
      "path": "/api/calendar/sources/:id",
      "description": "Delete calendar source"
    },
    {
      "method": "POST",
      "path": "/api/calendar/sync",
      "description": "Sync calendar sources"
    }
  ],

  "migrations": [
    "migrations/001_calendar_tables.sql",
    "migrations/002_calendar_permissions.sql"
  ],

  "cron": [
    {
      "schedule": "*/5 * * * *",
      "handler": "syncCalendars",
      "description": "Sync calendar sources every 5 minutes"
    }
  ],

  "settings": {
    "sync_interval": {
      "type": "number",
      "default": 300,
      "description": "Calendar sync interval in seconds"
    },
    "default_reminder": {
      "type": "number",
      "default": 15,
      "description": "Default reminder time in minutes"
    }
  },

  "frontendRoutes": [
    {
      "path": "/dashboard/calendar",
      "name": "Calendar",
      "icon": "Calendar"
    }
  ],

  "dependencies": {
    "googleapis": "^130.0.0",
    "ical.js": "^2.0.1",
    "node-fetch": "^3.3.2"
  }
}
