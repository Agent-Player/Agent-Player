# AGENT PLAYER WORKFLOW MANAGEMENT RULES - MANDATORY

## WORKFLOW SYSTEM RULES

### **Agent Lifecycle Management - MANDATORY**
```typescript
// Agent lifecycle must be tracked from creation to deletion
enum AgentLifecycleState {
  CREATED = 'created',
  CONFIGURING = 'configuring',
  TESTING = 'testing',
  ACTIVE = 'active',
  PAUSED = 'paused',
  TRAINING = 'training',
  ERROR = 'error',
  ARCHIVED = 'archived'
}

class AgentLifecycleManager {
  // MANDATORY: Track state transitions
  async transitionState(agentId: number, newState: AgentLifecycleState): Promise<void> {
    const currentState = await this.getCurrentState(agentId);
    
    // MANDATORY: Validate state transitions
    if (!this.isValidTransition(currentState, newState)) {
      throw new Error(`Invalid state transition from ${currentState} to ${newState}`);
    }
    
    // MANDATORY: Log state change
    await this.logStateChange(agentId, currentState, newState);
    
    // MANDATORY: Update agent state in database
    await this.updateAgentState(agentId, newState);
    
    // MANDATORY: Trigger state-specific actions
    await this.executeStateActions(agentId, newState);
  }
  
  private isValidTransition(from: AgentLifecycleState, to: AgentLifecycleState): boolean {
    const validTransitions = {
      [AgentLifecycleState.CREATED]: [AgentLifecycleState.CONFIGURING],
      [AgentLifecycleState.CONFIGURING]: [AgentLifecycleState.TESTING, AgentLifecycleState.ERROR],
      [AgentLifecycleState.TESTING]: [AgentLifecycleState.ACTIVE, AgentLifecycleState.ERROR],
      [AgentLifecycleState.ACTIVE]: [AgentLifecycleState.PAUSED, AgentLifecycleState.TRAINING, AgentLifecycleState.ARCHIVED],
      [AgentLifecycleState.PAUSED]: [AgentLifecycleState.ACTIVE, AgentLifecycleState.ARCHIVED],
      [AgentLifecycleState.TRAINING]: [AgentLifecycleState.ACTIVE, AgentLifecycleState.ERROR],
      [AgentLifecycleState.ERROR]: [AgentLifecycleState.CONFIGURING, AgentLifecycleState.ARCHIVED]
    };
    
    return validTransitions[from]?.includes(to) || false;
  }
}
```

### **Training Workflow Rules - MANDATORY**
```python
# Training workflow must handle complex multi-step processes
class TrainingWorkflow:
    def __init__(self, workspace_id: int):
        self.workspace_id = workspace_id
        self.current_step = 0
        self.total_steps = 0
        self.status = "initializing"
    
    async def execute_training_workflow(self):
        """Execute complete training workflow with checkpoints"""
        try:
            # MANDATORY: Initialize training environment
            await self.initialize_training_environment()
            
            # MANDATORY: Validate training data
            await self.validate_training_data()
            
            # MANDATORY: Setup LLM configurations
            await self.setup_llm_configurations()
            
            # MANDATORY: Execute training steps
            await self.execute_training_steps()
            
            # MANDATORY: Validate training results
            await self.validate_training_results()
            
            # MANDATORY: Deploy trained agent
            await self.deploy_trained_agent()
            
            # MANDATORY: Cleanup training resources
            await self.cleanup_training_resources()
            
            self.status = "completed"
            
        except Exception as e:
            # MANDATORY: Handle training failures
            await self.handle_training_failure(e)
            self.status = "failed"
    
    async def create_training_checkpoint(self):
        """Create checkpoint for recovery"""
        checkpoint_data = {
            "workspace_id": self.workspace_id,
            "current_step": self.current_step,
            "training_state": await self.get_training_state(),
            "timestamp": datetime.utcnow()
        }
        
        await self.save_checkpoint(checkpoint_data)
    
    async def recover_from_checkpoint(self, checkpoint_id: str):
        """Recover training from checkpoint"""
        checkpoint = await self.load_checkpoint(checkpoint_id)
        
        self.current_step = checkpoint["current_step"]
        await self.restore_training_state(checkpoint["training_state"])
        
        # MANDATORY: Resume from checkpoint
        await self.resume_training_from_step(self.current_step)
