### **Multi-Agent Communication Workflow - MANDATORY**
```typescript
// Multi-agent communication and coordination
class AgentCommunicationWorkflow {
  private agents: Map<number, Agent> = new Map();
  private communicationChannels: Map<string, WebSocket> = new Map();
  
  // MANDATORY: Setup agent communication
  async setupAgentCommunication(agentIds: number[]): Promise<void> {
    for (const agentId of agentIds) {
      const agent = await this.loadAgent(agentId);
      this.agents.set(agentId, agent);
      
      // MANDATORY: Create communication channel for each agent
      const channel = new WebSocket(`ws://localhost:8000/ws/agent/${agentId}`);
      this.communicationChannels.set(`agent_${agentId}`, channel);
      
      // MANDATORY: Setup message routing
      channel.onmessage = (event) => {
        this.routeAgentMessage(agentId, JSON.parse(event.data));
      };
    }
  }
  
  // MANDATORY: Route messages between agents
  private async routeAgentMessage(fromAgentId: number, message: AgentMessage): Promise<void> {
    // MANDATORY: Validate message format
    if (!this.validateMessage(message)) {
      throw new Error('Invalid agent message format');
    }
    
    // MANDATORY: Check agent permissions
    if (!await this.checkAgentPermissions(fromAgentId, message.action)) {
      throw new Error('Agent lacks permissions for this action');
    }
    
    // MANDATORY: Route to target agents
    if (message.targetAgents) {
      for (const targetAgentId of message.targetAgents) {
        await this.sendMessageToAgent(targetAgentId, message);
      }
    }
    
    // MANDATORY: Log communication
    await this.logAgentCommunication(fromAgentId, message);
  }
  
  // MANDATORY: Coordinate multi-agent tasks
  async coordinateMultiAgentTask(taskId: string, agentIds: number[]): Promise<void> {
    const task = await this.loadTask(taskId);
    
    // MANDATORY: Assign subtasks to agents
    const subtasks = await this.splitTaskIntoSubtasks(task, agentIds.length);
    
    for (let i = 0; i < agentIds.length; i++) {
      const agentId = agentIds[i];
      const subtask = subtasks[i];
      
      // MANDATORY: Send subtask to agent
      await this.assignSubtaskToAgent(agentId, subtask);
    }
    
    // MANDATORY: Monitor task progress
    await this.monitorMultiAgentTaskProgress(taskId, agentIds);
  }
}
```

### **User Permission Workflow - MANDATORY**
```python
# Complex permission and license validation workflow
class UserPermissionWorkflow:
    def __init__(self, user_id: int):
        self.user_id = user_id
        self.permissions_cache = {}
        self.license_cache = {}
    
    async def validate_user_action(self, action: str, resource_type: str, resource_id: str = None) -> bool:
        """Comprehensive permission validation"""
        
        # MANDATORY: Check user status
        user = await self.get_user(self.user_id)
        if not user.is_active:
            return False
        
        # MANDATORY: Check license permissions
        license_valid = await self.validate_license_permissions(action, resource_type)
        if not license_valid:
            return False
        
        # MANDATORY: Check role-based permissions
        role_permissions = await self.get_user_role_permissions(self.user_id)
        if action not in role_permissions:
            return False
        
        # MANDATORY: Check resource-specific permissions
        if resource_id:
            resource_permissions = await self.get_resource_permissions(resource_type, resource_id)
            if self.user_id not in resource_permissions.allowed_users:
                return False
        
        return True
    
    async def validate_license_permissions(self, action: str, resource_type: str) -> bool:
        """Validate license allows this action"""
        license_info = await self.get_user_license(self.user_id)
        
        if not license_info or license_info.is_expired:
            return False
        
        # MANDATORY: Check feature permissions
        required_features = self.get_required_features(action, resource_type)
        for feature in required_features:
            if feature not in license_info.enabled_features:
                return False
        
        return True
